<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:AudioBlocks.App.Controls"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="AudioBlocks.App.MainWindow"
        Width="1180" Height="820"
        MinWidth="920" MinHeight="620"
        Title="AudioBlocks"
        Icon="avares://AudioBlocks.App/Assets/logo.ico"
        Background="{DynamicResource AppBg}">

  <Window.Styles>

    <!-- ══════════ GLOBAL TRANSITIONS ══════════ -->
    <Style Selector="Border">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button">
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource CardBg}"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="Margin" Value="0,4"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.card:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBg}"/>
    </Style>

    <Style Selector="TextBlock.section">
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="{DynamicResource DimText}"/>
      <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style Selector="Button.sidebar-btn">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Height" Value="38"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="Foreground" Value="{DynamicResource FgText}"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style Selector="Button.sidebar-btn:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardSelected}"/>
      <Setter Property="RenderTransform" Value="translateX(2px)"/>
    </Style>
    <Style Selector="Button.sidebar-btn:pressed">
      <Setter Property="RenderTransform" Value="scale(0.98)"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <Style Selector="Button.monitor-btn">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut"/>
          <BrushTransition Property="Background" Duration="0:0:0.25"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.monitor-btn:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.015)"/>
      <Setter Property="Opacity" Value="0.92"/>
    </Style>
    <Style Selector="Button.monitor-btn:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)"/>
      <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <Style Selector="Button.lib-item">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="Foreground" Value="{DynamicResource FgText}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.lib-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardSelected}"/>
      <Setter Property="RenderTransform" Value="translateX(3px)"/>
    </Style>
    <Style Selector="Button.lib-item:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)"/>
    </Style>

    <Style Selector="Border.fx-dock-item">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="Margin" Value="0,2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.fx-dock-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardSelected}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource DimText}"/>
      <Setter Property="RenderTransform" Value="translateX(3px)"/>
    </Style>

    <Style Selector="Button.transport">
      <Setter Property="Height" Value="44"/>
      <Setter Property="MinWidth" Value="44"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="Foreground" Value="{DynamicResource FgText}"/>
      <Setter Property="Margin" Value="2,0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.transport:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardSelected}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource DimText}"/>
      <Setter Property="RenderTransform" Value="scale(1.06)"/>
    </Style>
    <Style Selector="Button.transport:pressed">
      <Setter Property="RenderTransform" Value="scale(0.93)"/>
      <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <Style Selector="Border.drop-target">
      <Setter Property="BorderBrush" Value="{DynamicResource DropTarget}"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="Border.stat-pill">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,6"/>
    </Style>
    <Style Selector="Separator">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="Height" Value="1"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="*,Auto">
    <Grid Grid.Row="0" ColumnDefinitions="250,*">

      <!-- ══════════════ SIDEBAR ══════════════ -->
      <Border Grid.Column="0" Background="{DynamicResource PanelBg}" Padding="16,14" CornerRadius="0,16,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10">

            <!-- ── BRAND ── -->
            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,2">
              <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" ClipToBounds="True" Margin="0,0,10,0">
                <Image Source="avares://AudioBlocks.App/Assets/logo.ico" Stretch="Uniform"/>
              </Border>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                <TextBlock Text="AudioBlocks" FontSize="20" FontWeight="ExtraBold" Foreground="{DynamicResource FgText}"/>
                <TextBlock Text="Live Audio FX Engine" Foreground="{DynamicResource DimText}" FontSize="10" Opacity="0.7"/>
              </StackPanel>
            </Grid>

            <Separator Margin="0,2"/>

            <!-- ── MONITORING ── -->
            <Button x:Name="ToggleMonitoringButton" Classes="monitor-btn">
              <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <i:Icon Value="mdi-headphones" FontSize="20" Foreground="White"/>
                <TextBlock Text="Start Monitoring" VerticalAlignment="Center" FontSize="14"/>
              </StackPanel>
            </Button>
            <TextBlock x:Name="StatusLabel" Text="Ready" Foreground="{DynamicResource MutedText}" TextWrapping="Wrap" FontSize="11" Margin="2,0" Opacity="0.8"/>

            <Separator/>

            <!-- ── NAV BUTTONS ── -->
            <Button x:Name="OpenSettingsButton" Classes="sidebar-btn">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <i:Icon Value="mdi-cog" FontSize="16" Foreground="{DynamicResource MutedText}"/>
                <TextBlock Text="Settings" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="ToggleLibraryButton" Classes="sidebar-btn">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <i:Icon Value="mdi-view-grid-plus" FontSize="16" Foreground="{DynamicResource MutedText}"/>
                <TextBlock Text="Effects Library" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Separator/>

            <!-- ── STATS ── -->
            <TextBlock Classes="section" Text="PERFORMANCE"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
              <Border Grid.Column="0" Classes="stat-pill">
                <StackPanel Spacing="1">
                  <TextBlock Text="CPU" FontSize="9" Foreground="{DynamicResource DimText}" FontWeight="Bold"/>
                  <TextBlock x:Name="CpuLabel" Text="--" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="stat-pill">
                <StackPanel Spacing="1">
                  <TextBlock Text="LATENCY" FontSize="9" Foreground="{DynamicResource DimText}" FontWeight="Bold"/>
                  <TextBlock x:Name="LatencySmallLabel" Text="--" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
              </Border>
            </Grid>

            <!-- ── LEVEL METER ── -->
            <TextBlock Classes="section" Text="LEVEL" Margin="0,4,0,1"/>
            <c:LevelMeter x:Name="VuMeter" Height="20"/>
            <TextBlock x:Name="PeakDbLabel" Text="-inf dB" Foreground="{DynamicResource DimText}" FontSize="10" HorizontalAlignment="Right" FontFamily="Consolas" Opacity="0.7"/>

            <Separator/>

            <!-- ── MASTER FADER ── -->
            <TextBlock Classes="section" Text="MASTER"/>
            <Grid ColumnDefinitions="*,46">
              <c:FaderControl x:Name="MasterFader" Minimum="0" Maximum="2" Value="1" DefaultValue="1" Height="28"
                              Accent="{DynamicResource AccentCyan}" Label=""/>
              <TextBlock x:Name="MasterValueLabel" Text="0 dB" Grid.Column="1" Foreground="{DynamicResource FgText}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"/>
            </Grid>

            <Separator/>

            <!-- ── METRONOME ── -->
            <TextBlock Classes="section" Text="METRONOME"/>
            <Border Classes="stat-pill" Padding="8,6">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <ToggleButton x:Name="MetronomeToggle" Width="38" Height="28" FontSize="10" Content="ON"
                                Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource FgText}" FontWeight="Bold" CornerRadius="6"/>
                  <Button x:Name="BpmDownButton" Width="28" Height="28" Content="−" Background="Transparent" Foreground="{DynamicResource FgText}" CornerRadius="6" FontSize="14"/>
                  <TextBox x:Name="BpmBox" Text="120" Foreground="{DynamicResource FgText}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Width="58" TextAlignment="Center" BorderThickness="0" Background="Transparent" Padding="0" CaretBrush="{DynamicResource FgText}" FontFamily="Consolas"/>
                  <Button x:Name="BpmUpButton" Width="28" Height="28" Content="+" Background="Transparent" Foreground="{DynamicResource FgText}" CornerRadius="6" FontSize="14"/>
                  <TextBlock x:Name="BeatIndicator" Text="1/4" Foreground="{DynamicResource AccentCyan}" FontSize="14" FontWeight="ExtraBold" VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="Consolas"/>
                </StackPanel>
                <Grid ColumnDefinitions="*,36">
                  <c:FaderControl x:Name="MetronomeVolumeFader" Minimum="0" Maximum="1" Value="0.5" DefaultValue="0.5" Height="22"
                                  Accent="{DynamicResource AccentPurple}" Label=""/>
                  <TextBlock x:Name="MetronomeVolLabel" Grid.Column="1" Text="50%" Foreground="{DynamicResource DimText}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas"/>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ══════════════ MAIN CONTENT ══════════════ -->
      <Grid Grid.Column="1" ColumnDefinitions="*,Auto">

        <!-- EFFECT CHAIN -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="12,12,0,12">
          <StackPanel Spacing="8">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <i:Icon Value="mdi-link-variant" FontSize="20" Foreground="{DynamicResource AccentCyan}"/>
                <TextBlock Text="Effect Chain" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource FgText}" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <Button x:Name="MoveUpButton" Height="30" Width="30" Padding="0" CornerRadius="8" Background="{DynamicResource SurfaceBg}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                  <i:Icon Value="mdi-chevron-up" FontSize="16" Foreground="{DynamicResource FgText}"/>
                </Button>
                <Button x:Name="MoveDownButton" Height="30" Width="30" Padding="0" CornerRadius="8" Background="{DynamicResource SurfaceBg}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                  <i:Icon Value="mdi-chevron-down" FontSize="16" Foreground="{DynamicResource FgText}"/>
                </Button>
                <Button x:Name="RebuildGraphButton" Height="30" Padding="10,0" CornerRadius="8" Background="{DynamicResource SurfaceBg}" FontSize="11" FontWeight="SemiBold">
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <i:Icon Value="mdi-refresh" FontSize="14" Foreground="{DynamicResource MutedText}"/>
                    <TextBlock Text="Rebuild" VerticalAlignment="Center" Foreground="{DynamicResource MutedText}"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Grid>

            <!-- Drop zone -->
            <Border x:Name="DropZone" MinHeight="140" CornerRadius="12" Padding="0" Background="Transparent" DragDrop.AllowDrop="True">
              <Grid>
                <StackPanel x:Name="EffectsPanel" Spacing="6"/>
                <Border x:Name="EmptyChainHint" IsVisible="True" VerticalAlignment="Center"
                        Background="{DynamicResource CardDefault}" CornerRadius="16" Padding="40,34" Opacity="0.95">
                  <StackPanel HorizontalAlignment="Center" Spacing="14">
                    <i:Icon Value="mdi-link-variant-plus" FontSize="48" Foreground="{DynamicResource DimText}" Opacity="0.4"/>
                    <TextBlock Text="Build your signal chain" Foreground="{DynamicResource FgText}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Drag effects from the library, or click below" Foreground="{DynamicResource DimText}" FontSize="12" HorizontalAlignment="Center" Opacity="0.7"/>
                    <Button x:Name="EmptyOpenLibraryBtn" HorizontalAlignment="Center" Height="38" Padding="20,0" CornerRadius="10"
                            Background="{DynamicResource AccentCyan}" Foreground="White" FontWeight="Bold" FontSize="12">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <i:Icon Value="mdi-plus" FontSize="18" Foreground="White"/>
                        <TextBlock Text="Add Effects" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </Border>
              </Grid>
            </Border>

            <!-- Log -->
            <Border Classes="card" Margin="0,4">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <i:Icon Value="mdi-text-box-outline" FontSize="13" Foreground="{DynamicResource DimText}"/>
                  <TextBlock Text="Log" FontWeight="SemiBold" Foreground="{DynamicResource MutedText}" FontSize="11"/>
                </StackPanel>
                <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="56"
                         Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource MutedText}" FontSize="10" CornerRadius="8" FontFamily="Consolas"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <!-- ══════════════ DOCKED LIBRARY ══════════════ -->
        <Border x:Name="LibraryPanel" Grid.Column="1" Width="240" Background="{DynamicResource PanelBg}" Padding="14" IsVisible="False" CornerRadius="16,0,0,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                <i:Icon Value="mdi-view-grid-plus" FontSize="18" Foreground="{DynamicResource AccentCyan}"/>
                <TextBlock Text="Effects Library" FontSize="16" FontWeight="ExtraBold" Foreground="{DynamicResource FgText}"/>
              </StackPanel>
              <TextBlock Text="Click or drag to chain" Foreground="{DynamicResource DimText}" FontSize="10" Margin="0,0,0,6" Opacity="0.6"/>

              <TextBlock Text="DYNAMICS" Foreground="{DynamicResource AccentBrush}" FontSize="9" FontWeight="ExtraBold" Margin="0,4,0,3"/>
              <Border Classes="fx-dock-item" x:Name="DockDragGain" Tag="Gain"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-volume-high" FontSize="15" Foreground="{DynamicResource AccentBrush}"/><TextBlock Text="Gain Boost" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>
              <Border Classes="fx-dock-item" x:Name="DockDragCompressor" Tag="Compressor"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-arrow-collapse-vertical" FontSize="15" Foreground="{DynamicResource AccentBrush}"/><TextBlock Text="Compressor" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>
              <Border Classes="fx-dock-item" x:Name="DockDragGate" Tag="NoiseGate"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-gate" FontSize="15" Foreground="{DynamicResource AccentBrush}"/><TextBlock Text="Noise Gate" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>

              <TextBlock Text="TONE" Foreground="{DynamicResource AccentCyan}" FontSize="9" FontWeight="ExtraBold" Margin="0,8,0,3"/>
              <Border Classes="fx-dock-item" x:Name="DockDragEq" Tag="EQ"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-equalizer" FontSize="15" Foreground="{DynamicResource AccentCyan}"/><TextBlock Text="EQ (3-Band)" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>
              <Border Classes="fx-dock-item" x:Name="DockDragDistortion" Tag="Distortion"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-flash-alert" FontSize="15" Foreground="{DynamicResource AccentCyan}"/><TextBlock Text="Distortion" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>
              <Border Classes="fx-dock-item" x:Name="DockDragFuzz" Tag="Fuzz"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-waveform" FontSize="15" Foreground="{DynamicResource AccentCyan}"/><TextBlock Text="Fuzz" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>
              <Border Classes="fx-dock-item" x:Name="DockDragGraphicEq" Tag="GraphicEQ"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-chart-bar" FontSize="15" Foreground="{DynamicResource AccentCyan}"/><TextBlock Text="Graphic EQ" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>

              <TextBlock Text="TIME / MOD" Foreground="{DynamicResource AccentPurple}" FontSize="9" FontWeight="ExtraBold" Margin="0,8,0,3"/>
              <Border Classes="fx-dock-item" x:Name="DockDragDelay" Tag="Delay"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-timer-outline" FontSize="15" Foreground="{DynamicResource AccentPurple}"/><TextBlock Text="Delay" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>
              <Border Classes="fx-dock-item" x:Name="DockDragReverb" Tag="Reverb"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-waves" FontSize="15" Foreground="{DynamicResource AccentPurple}"/><TextBlock Text="Reverb" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>
              <Border Classes="fx-dock-item" x:Name="DockDragChorus" Tag="Chorus"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-music-note" FontSize="15" Foreground="{DynamicResource AccentPurple}"/><TextBlock Text="Chorus" VerticalAlignment="Center" Foreground="{DynamicResource FgText}" FontSize="12"/></StackPanel></Border>

              <Separator Margin="0,8"/>
              <TextBlock Text="PRESETS" Foreground="{DynamicResource MutedText}" FontSize="9" FontWeight="ExtraBold"/>
              <Button x:Name="PresetCleanBtn" Classes="lib-item"><StackPanel Orientation="Horizontal" Spacing="8"><Ellipse Width="8" Height="8" Fill="{DynamicResource BlockGreen}"/><TextBlock Text="Clean Tone" VerticalAlignment="Center"/></StackPanel></Button>
              <Button x:Name="PresetCrunchBtn" Classes="lib-item"><StackPanel Orientation="Horizontal" Spacing="8"><Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}"/><TextBlock Text="Crunch" VerticalAlignment="Center"/></StackPanel></Button>
              <Button x:Name="PresetLeadBtn" Classes="lib-item"><StackPanel Orientation="Horizontal" Spacing="8"><Ellipse Width="8" Height="8" Fill="{DynamicResource BlockAmber}"/><TextBlock Text="Lead" VerticalAlignment="Center"/></StackPanel></Button>
              <Button x:Name="PresetAmbientBtn" Classes="lib-item"><StackPanel Orientation="Horizontal" Spacing="8"><Ellipse Width="8" Height="8" Fill="{DynamicResource AccentPurple}"/><TextBlock Text="Ambient" VerticalAlignment="Center"/></StackPanel></Button>

              <Separator Margin="0,6"/>
              <Button x:Name="SavePresetDockBtn" Classes="lib-item"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-content-save" FontSize="14" Foreground="{DynamicResource AccentBrush}"/><TextBlock Text="Save Current Chain" VerticalAlignment="Center"/></StackPanel></Button>
              <StackPanel x:Name="SaveDockPanel" Orientation="Horizontal" Spacing="4" IsVisible="False" Margin="0,2">
                <TextBox x:Name="PresetNameDockBox" Watermark="Preset name..." FontSize="11" MinWidth="130" Height="28" CornerRadius="6"/>
                <Button x:Name="SaveConfirmDockBtn" Height="28" Width="28" CornerRadius="6" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBg}">
                  <i:Icon Value="mdi-check" FontSize="16" Foreground="{DynamicResource BlockGreen}"/>
                </Button>
              </StackPanel>
              <Separator Margin="0,4"/>
              <TextBlock Text="USER PRESETS" Foreground="{DynamicResource MutedText}" FontSize="9" FontWeight="ExtraBold"/>
              <StackPanel x:Name="UserPresetsDockPanel" Spacing="2"/>
              <Separator Margin="0,4"/>
              <Button x:Name="ExportPresetDockBtn" Classes="lib-item"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-export" FontSize="14" Foreground="{DynamicResource DimText}"/><TextBlock Text="Export Preset..." VerticalAlignment="Center"/></StackPanel></Button>
              <Button x:Name="ImportPresetDockBtn" Classes="lib-item"><StackPanel Orientation="Horizontal" Spacing="8"><i:Icon Value="mdi-import" FontSize="14" Foreground="{DynamicResource DimText}"/><TextBlock Text="Import Preset..." VerticalAlignment="Center"/></StackPanel></Button>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>

    <!-- ══════════════ TRANSPORT BAR ══════════════ -->
    <Border Grid.Row="1" Background="{DynamicResource PanelBg}" Padding="16,10" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SurfaceBg}">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
          <Button x:Name="RecordButton" Classes="transport" ToolTip.Tip="Record">
            <Ellipse Width="16" Height="16" Fill="#EF4444"/>
          </Button>
          <Button x:Name="PlayButton" Classes="transport" ToolTip.Tip="Play">
            <PathIcon Width="16" Height="16" Foreground="{DynamicResource FgText}" Data="M8,5V19l11-7Z"/>
          </Button>
          <Button x:Name="StopButton" Classes="transport" ToolTip.Tip="Stop">
            <Border Width="14" Height="14" Background="{DynamicResource FgText}" CornerRadius="2"/>
          </Button>
          <Button x:Name="ExportButton" Classes="transport" ToolTip.Tip="Export WAV">
            <i:Icon Value="mdi-download" FontSize="18" Foreground="{DynamicResource FgText}"/>
          </Button>
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
          <TextBlock x:Name="RecordTimeLabel" Text="00:00.0" Foreground="{DynamicResource MutedText}" FontSize="16" FontFamily="Consolas" FontWeight="Bold"/>
          <ProgressBar x:Name="PlaybackProgress" Minimum="0" Maximum="1" Value="0" Width="180" Height="5" VerticalAlignment="Center" CornerRadius="3"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>