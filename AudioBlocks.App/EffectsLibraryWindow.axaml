<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="AudioBlocks.App.EffectsLibraryWindow"
        Width="290" Height="640"
        MinWidth="240" MinHeight="400"
        Title="Effects Library"
        Icon="avares://AudioBlocks.App/Assets/logo.ico"
        Background="{DynamicResource AppBg}"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

  <Window.Styles>
    <Style Selector="Border">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.fx-item">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Margin" Value="0,2,6,2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="RenderTransform" Value="none"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.fx-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardSelected}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource DimText}"/>
      <Setter Property="RenderTransform" Value="translateX(2px)"/>
    </Style>
    <Style Selector="Border.preset-item">
      <Setter Property="Background" Value="{DynamicResource CardBg}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="Margin" Value="0,2,6,2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="RenderTransform" Value="none"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.preset-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource CardSelected}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource DimText}"/>
      <Setter Property="RenderTransform" Value="translateX(2px)"/>
    </Style>
    <Style Selector="Separator">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
      <Setter Property="Height" Value="1"/>
    </Style>
  </Window.Styles>

  <Border Background="{DynamicResource PanelBg}" Padding="14">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <i:Icon Value="mdi-view-dashboard" FontSize="20" Foreground="{DynamicResource AccentCyan}"/>
          <TextBlock Text="Effects Library" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource FgText}"/>
        </StackPanel>
        <TextBlock Text="Click to add · Drag to chain" Foreground="{DynamicResource DimText}" FontSize="11"/>
        <Separator Margin="0,4"/>

        <!-- ═══ DYNAMICS ═══ -->
        <TextBlock Text="DYNAMICS" Foreground="{DynamicResource AccentBrush}" FontSize="9" FontWeight="ExtraBold" Margin="0,4,0,2"/>
        <Border Classes="fx-item" x:Name="DragGain" Tag="Gain">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-volume-high" FontSize="18" Foreground="{DynamicResource AccentBrush}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Gain Boost" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Volume / drive level" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Classes="fx-item" x:Name="DragCompressor" Tag="Compressor">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-arrow-collapse-vertical" FontSize="18" Foreground="{DynamicResource AccentBrush}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Compressor" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Dynamic range control" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Classes="fx-item" x:Name="DragGate" Tag="NoiseGate">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-gate" FontSize="18" Foreground="{DynamicResource AccentBrush}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Noise Gate" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Cut silence / hum" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ═══ TONE ═══ -->
        <TextBlock Text="TONE" Foreground="{DynamicResource AccentCyan}" FontSize="9" FontWeight="ExtraBold" Margin="0,8,0,2"/>
        <Border Classes="fx-item" x:Name="DragEq" Tag="EQ">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-equalizer" FontSize="18" Foreground="{DynamicResource AccentCyan}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="EQ (3-Band)" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Low / Mid / High" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Classes="fx-item" x:Name="DragDistortion" Tag="Distortion">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-flash-alert" FontSize="18" Foreground="{DynamicResource AccentCyan}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Distortion" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Overdrive / clipping" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Classes="fx-item" x:Name="DragFuzz" Tag="Fuzz">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-waveform" FontSize="18" Foreground="{DynamicResource AccentCyan}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Fuzz" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Heavy saturation" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Classes="fx-item" x:Name="DragGraphicEq" Tag="GraphicEQ">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-chart-bar" FontSize="18" Foreground="{DynamicResource AccentCyan}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Graphic EQ (10-Band)" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Precision frequency control" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ═══ TIME / MOD ═══ -->
        <TextBlock Text="TIME / MOD" Foreground="{DynamicResource AccentPurple}" FontSize="9" FontWeight="ExtraBold" Margin="0,8,0,2"/>
        <Border Classes="fx-item" x:Name="DragDelay" Tag="Delay">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-timer-outline" FontSize="18" Foreground="{DynamicResource AccentPurple}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Delay" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Echo / repeat" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Classes="fx-item" x:Name="DragReverb" Tag="Reverb">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-waves" FontSize="18" Foreground="{DynamicResource AccentPurple}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Reverb" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Room / space" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Classes="fx-item" x:Name="DragChorus" Tag="Chorus">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <i:Icon Value="mdi-music-note" FontSize="18" Foreground="{DynamicResource AccentPurple}"/>
            <StackPanel Spacing="0">
              <TextBlock Text="Chorus" Foreground="{DynamicResource FgText}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="Detune / widen" Foreground="{DynamicResource DimText}" FontSize="10"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Separator Margin="0,8"/>

        <!-- ═══ PRESETS ═══ -->
        <TextBlock Text="PRESETS" Foreground="{DynamicResource MutedText}" FontSize="9" FontWeight="ExtraBold"/>
        <Border Classes="preset-item" x:Name="PresetClean" Tag="Clean">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource BlockGreen}"/>
            <TextBlock Text="Clean Tone" Foreground="{DynamicResource FgText}" FontSize="12"/>
          </StackPanel>
        </Border>
        <Border Classes="preset-item" x:Name="PresetCrunch" Tag="Crunch">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}"/>
            <TextBlock Text="Crunch" Foreground="{DynamicResource FgText}" FontSize="12"/>
          </StackPanel>
        </Border>
        <Border Classes="preset-item" x:Name="PresetLead" Tag="Lead">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource BlockAmber}"/>
            <TextBlock Text="Lead" Foreground="{DynamicResource FgText}" FontSize="12"/>
          </StackPanel>
        </Border>
        <Border Classes="preset-item" x:Name="PresetAmbient" Tag="Ambient">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentPurple}"/>
            <TextBlock Text="Ambient" Foreground="{DynamicResource FgText}" FontSize="12"/>
          </StackPanel>
        </Border>

        <!-- ═══ SAVE ═══ -->
        <Border Classes="preset-item" x:Name="SavePresetBtn" Margin="0,6,6,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <i:Icon Value="mdi-content-save" FontSize="14" Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Text="Save Current Chain" Foreground="{DynamicResource AccentBrush}" FontSize="12"/>
          </StackPanel>
        </Border>
        <StackPanel x:Name="SavePanel" Orientation="Horizontal" Spacing="4" IsVisible="False" Margin="0,2">
          <TextBox x:Name="PresetNameBox" Watermark="Preset name..." FontSize="12" MinWidth="160" Height="28" CornerRadius="6"/>
          <Button x:Name="SaveConfirmBtn" Height="28" Width="28" CornerRadius="6" Padding="0"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Background="{DynamicResource SurfaceBg}">
            <i:Icon Value="mdi-check" FontSize="16" Foreground="{DynamicResource BlockGreen}"/>
          </Button>
        </StackPanel>

        <Separator Margin="0,6"/>
        <TextBlock Text="USER PRESETS" Foreground="{DynamicResource MutedText}" FontSize="9" FontWeight="ExtraBold"/>
        <StackPanel x:Name="UserPresetsPanel" Spacing="2"/>

        <Separator Margin="0,6"/>
        <Border Classes="preset-item" x:Name="ExportPresetBtn">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <i:Icon Value="mdi-export" FontSize="14" Foreground="{DynamicResource FgText}"/>
            <TextBlock Text="Export Preset..." Foreground="{DynamicResource FgText}" FontSize="12"/>
          </StackPanel>
        </Border>
        <Border Classes="preset-item" x:Name="ImportPresetBtn">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <i:Icon Value="mdi-import" FontSize="14" Foreground="{DynamicResource FgText}"/>
            <TextBlock Text="Import Preset..." Foreground="{DynamicResource FgText}" FontSize="12"/>
          </StackPanel>
        </Border>

        <Separator Margin="0,6"/>
        <TextBlock x:Name="StatusLabel" Text="" Foreground="{DynamicResource AccentCyan}" FontSize="11" HorizontalAlignment="Center"/>
      </StackPanel>
    </ScrollViewer>
  </Border>
</Window>